<%- include('partials/layout-top', { title: 'Dashboard' }) %>

<section class="grid-stats">
  <article class="stat-card">
    <h2>Total</h2>
    <p data-summary="total"><%= summary.total %></p>
  </article>
  <article class="stat-card">
    <h2>Groups</h2>
    <p data-summary="groups"><%= summary.groups %></p>
  </article>
  <article class="stat-card up">
    <h2>Up</h2>
    <p data-summary="up"><%= summary.up %></p>
  </article>
  <article class="stat-card down">
    <h2>Down</h2>
    <p data-summary="down"><%= summary.down %></p>
  </article>
  <article class="stat-card unknown">
    <h2>Unknown</h2>
    <p data-summary="unknown"><%= summary.unknown %></p>
  </article>
</section>

<section class="card live-meta">
  <div class="row-actions">
    <span class="live-pill">Live Dashboard</span>
    <span class="cell-sub">Updated <time id="js-live-updated" class="js-local-time" datetime="<%= generatedAt %>" data-style="datetime"><%= generatedAt %></time></span>
  </div>
</section>

<section class="card">
  <div class="section-head">
    <h2>Active Outages</h2>
    <span class="subtitle" id="js-active-outages-count"><%= activeOutages.length %> active</span>
  </div>
  <div id="js-active-outages-list" class="active-outage-list">
    <% if (activeOutages.length === 0) { %>
    <p class="empty">No active outages.</p>
    <% } else { %>
      <% activeOutages.forEach((outage) => { %>
      <article class="active-outage-item" data-outage-monitor-id="<%= outage.monitorId %>">
        <div class="active-outage-head">
          <strong><%= outage.monitorName %></strong>
          <span class="status down">down</span>
        </div>
        <p class="cell-sub"><%= outage.groupName %> - <%= outage.target %></p>
        <p class="cell-sub">Down since: <time class="js-local-time" datetime="<%= outage.downSince || '' %>" data-style="datetime"><%= outage.downSince || '-' %></time></p>
        <p class="cell-sub">Duration: <span class="js-duration" data-duration-seconds="<%= outage.durationSeconds === null || outage.durationSeconds === undefined ? '' : outage.durationSeconds %>"><%= outage.durationSeconds === null || outage.durationSeconds === undefined ? '-' : `${outage.durationSeconds}s` %></span></p>
        <p class="target"><%= outage.reason %></p>
      </article>
      <% }) %>
    <% } %>
  </div>
</section>

<section class="card">
  <div class="section-head">
    <h1>Monitors</h1>
    <div class="row-actions">
      <a class="button muted" href="/groups">Manage Groups</a>
      <a class="button muted" href="/status-pages">Manage Status Pages</a>
      <a class="button" href="/monitors/new">Add Monitor</a>
    </div>
  </div>

  <% if (groupedMonitors.length === 0) { %>
  <p class="empty">No monitors yet.</p>
  <% } else { %>
    <div id="js-monitor-groups">
    <% groupedMonitors.forEach((group) => { %>
    <section class="monitor-group" data-group-id="<%= group.groupId || 'ungrouped' %>">
      <div class="section-head group-head">
        <h3 class="group-title"><%= group.groupName %> <span data-group-count="<%= group.groupId || 'ungrouped' %>">(<%= group.monitors.length %>)</span></h3>
        <form action="/groups/<%= group.groupId || 'ungrouped' %>/alert" method="post">
          <button class="button small muted" type="submit">Alert Group</button>
        </form>
      </div>
      <div class="table-wrap">
        <table class="monitor-table">
          <thead>
            <tr>
              <th>Status</th>
              <th>Name</th>
              <th>Hostname</th>
              <th>Type</th>
              <th>Last Check</th>
              <th>Next Check</th>
              <th>Outage</th>
              <th>Last Error</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% group.monitors.forEach((monitor) => { %>
            <tr class="monitor-row <%= monitor.runtime.status %>" data-monitor-id="<%= monitor.id %>" data-group-id="<%= group.groupId || 'ungrouped' %>">
              <td class="status-cell">
                <span class="status <%= monitor.runtime.status %>" data-field="status"><%= monitor.hasUnconfirmedFailures ? 'up (confirming)' : monitor.runtime.status %></span>
              </td>
              <td>
                <span class="cell-title" data-field="name"><%= monitor.name %></span>
                <span class="monitor-chip <%= monitor.active ? 'active' : 'paused' %>" data-field="active-chip"><%= monitor.active ? 'Active' : 'Paused' %></span>
              </td>
              <td class="target host-cell" data-field="target" title="<%= monitor.target %>"><%= monitor.target %></td>
              <td data-field="check-type"><%= monitor.checkType %></td>
              <td>
                <% if (monitor.runtime.lastCheckAt) { %>
                <time class="js-local-time" data-field="last-check" datetime="<%= monitor.runtime.lastCheckAt %>" data-style="datetime"><%= monitor.runtime.lastCheckAt %></time>
                <% } else { %>
                <span data-field="last-check" data-empty-label="Never">Never</span>
                <% } %>
              </td>
              <td>
                <% if (monitor.runtime.nextCheckAt) { %>
                <time class="js-local-time" data-field="next-check" datetime="<%= monitor.runtime.nextCheckAt %>" data-style="time"><%= monitor.runtime.nextCheckAt %></time>
                <% } else { %>
                <span data-field="next-check" data-empty-label="-">-</span>
                <% } %>
              </td>
              <td class="outage-cell">
                <div data-field="outage-label">
                  <% if (monitor.outage.active && monitor.outage.startedAt) { %>
                  <time class="js-local-time" datetime="<%= monitor.outage.startedAt %>" data-style="datetime"><%= monitor.outage.startedAt %></time>
                  <% } else { %>
                  -
                  <% } %>
                </div>
                <div class="cell-sub" data-field="outage-duration" data-duration-seconds="<%= monitor.outage.durationSeconds === null || monitor.outage.durationSeconds === undefined ? '' : monitor.outage.durationSeconds %>"><%= monitor.outage.durationSeconds === null || monitor.outage.durationSeconds === undefined ? '-' : `${monitor.outage.durationSeconds}s` %></div>
              </td>
              <td class="target" data-field="last-error" title="<%= monitor.runtime.lastError || '-' %>"><%= monitor.runtime.lastError || '-' %></td>
              <td class="actions-cell">
                <details class="action-menu">
                  <summary class="button small muted">Actions</summary>
                  <div class="action-menu-list">
                    <form action="/monitors/<%= monitor.id %>/alert" method="post">
                      <button class="action-menu-item" type="submit">Alert Monitor</button>
                    </form>
                    <a class="action-menu-item" href="/monitors/<%= monitor.id %>/edit">Edit</a>
                    <form action="/monitors/<%= monitor.id %>/move" method="post">
                      <input type="hidden" name="direction" value="up" />
                      <button class="action-menu-item" type="submit">Move Up</button>
                    </form>
                    <form action="/monitors/<%= monitor.id %>/move" method="post">
                      <input type="hidden" name="direction" value="down" />
                      <button class="action-menu-item" type="submit">Move Down</button>
                    </form>
                    <form action="/monitors/<%= monitor.id %>/toggle" method="post">
                      <button class="action-menu-item" type="submit" data-field="toggle-label"><%= monitor.active ? 'Pause' : 'Resume' %></button>
                    </form>
                    <form action="/monitors/<%= monitor.id %>/delete" method="post" onsubmit="return confirm('Delete this monitor?');">
                      <button class="action-menu-item danger" type="submit">Delete</button>
                    </form>
                  </div>
                </details>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
    <% }) %>
    </div>
  <% } %>
</section>

<section class="card">
  <h2>Incident History (3 years retained)</h2>

  <% if (incidents.length === 0) { %>
  <p class="empty">No incidents recorded yet.</p>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Monitor</th>
          <th>Started</th>
          <th>Ended</th>
          <th>Duration</th>
          <th>Down Reason</th>
          <th>Recovery</th>
        </tr>
      </thead>
      <tbody>
        <% incidents.forEach((incident) => { %>
        <tr>
          <td><%= incident.monitorName %></td>
          <td><time class="js-local-time" datetime="<%= incident.startedAt %>" data-style="datetime"><%= incident.startedAt %></time></td>
          <td>
            <% if (incident.endedAt) { %>
            <time class="js-local-time" datetime="<%= incident.endedAt %>" data-style="datetime"><%= incident.endedAt %></time>
            <% } else { %>
            Open
            <% } %>
          </td>
          <td><span class="js-duration" data-duration-seconds="<%= incident.durationSeconds === null || incident.durationSeconds === undefined ? '' : incident.durationSeconds %>"><%= incident.durationSeconds === null || incident.durationSeconds === undefined ? '-' : `${incident.durationSeconds}s` %></span></td>
          <td class="target"><%= incident.downReason || '-' %></td>
          <td class="target"><%= incident.recoveryReason || '-' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h2>Event Log</h2>
    <p class="subtitle">Page <%= eventPagination.page %> of <%= eventPagination.totalPages %></p>
  </div>

  <% if (events.length === 0) { %>
  <p class="empty">No events yet.</p>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Time</th>
          <th>Monitor</th>
          <th>Type</th>
          <th>Message</th>
        </tr>
      </thead>
      <tbody>
        <% events.forEach((event) => { %>
        <tr>
          <td><time class="js-local-time" datetime="<%= event.createdAt %>" data-style="datetime"><%= event.createdAt %></time></td>
          <td><%= event.monitorName || '-' %></td>
          <td><%= event.eventType %></td>
          <td class="target"><%= event.message %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

  <% if (eventPagination.totalPages > 1) { %>
  <div class="row-actions">
    <% if (eventPagination.hasPrev) { %>
    <a class="button small muted" href="/?eventsPage=<%= eventPagination.page - 1 %>">Previous</a>
    <% } %>
    <% if (eventPagination.hasNext) { %>
    <a class="button small muted" href="/?eventsPage=<%= eventPagination.page + 1 %>">Next</a>
    <% } %>
  </div>
  <% } %>
</section>

<script>
  (function () {
    function formatDuration(seconds) {
      if (!Number.isFinite(seconds) || seconds < 0) {
        return '-';
      }

      const whole = Math.round(seconds);
      if (whole < 60) {
        return `${whole}s`;
      }

      const mins = Math.floor(whole / 60);
      const sec = whole % 60;
      if (mins < 60) {
        return sec === 0 ? `${mins}m` : `${mins}m ${sec}s`;
      }

      const hrs = Math.floor(mins / 60);
      const remMins = mins % 60;
      if (hrs < 24) {
        return remMins === 0 ? `${hrs}h` : `${hrs}h ${remMins}m`;
      }

      const days = Math.floor(hrs / 24);
      const remHrs = hrs % 24;
      return remHrs === 0 ? `${days}d` : `${days}d ${remHrs}h`;
    }

    function setLocalizedTime(node, iso, style) {
      if (!node) {
        return;
      }

      if (!iso) {
        node.textContent = node.getAttribute('data-empty-label') || '-';
        node.removeAttribute('datetime');
        return;
      }

      const date = new Date(iso);
      if (Number.isNaN(date.getTime())) {
        node.textContent = iso;
        return;
      }

      node.setAttribute('datetime', iso);
      node.setAttribute('data-style', style || 'datetime');
      node.textContent = style === 'time' ? date.toLocaleTimeString() : date.toLocaleString();
    }

    function localizeTimes() {
      const nodes = document.querySelectorAll('.js-local-time[datetime]');
      for (const node of nodes) {
        setLocalizedTime(node, node.getAttribute('datetime'), node.getAttribute('data-style') || 'datetime');
      }
    }

    function renderDurationNodes() {
      const nodes = document.querySelectorAll('.js-duration[data-duration-seconds], [data-field="outage-duration"][data-duration-seconds]');
      for (const node of nodes) {
        const raw = node.getAttribute('data-duration-seconds');
        const num = raw === '' || raw === null ? NaN : Number(raw);
        node.textContent = Number.isFinite(num) ? formatDuration(num) : '-';
      }
    }

    function escapeHtml(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function monitorIdsFromPayload(groupedMonitors) {
      const ids = [];
      for (const group of groupedMonitors) {
        for (const monitor of group.monitors) {
          ids.push(monitor.id);
        }
      }
      ids.sort();
      return ids;
    }

    function monitorIdsFromDom() {
      const ids = Array.from(document.querySelectorAll('tr[data-monitor-id]')).map((node) => node.getAttribute('data-monitor-id'));
      ids.sort();
      return ids;
    }

    function updateActiveOutages(snapshot) {
      const list = document.getElementById('js-active-outages-list');
      const count = document.getElementById('js-active-outages-count');
      if (!list || !count) {
        return;
      }

      const outages = Array.isArray(snapshot.activeOutages) ? snapshot.activeOutages : [];
      count.textContent = `${outages.length} active`;

      if (outages.length === 0) {
        list.innerHTML = '<p class="empty">No active outages.</p>';
        return;
      }

      list.innerHTML = outages
        .map((outage) => {
          const downSince = outage.downSince || '';
          const duration = Number.isFinite(Number(outage.durationSeconds)) ? Number(outage.durationSeconds) : null;
          const safeName = escapeHtml(outage.monitorName);
          const safeGroup = escapeHtml(outage.groupName);
          const safeTarget = escapeHtml(outage.target);
          const safeReason = escapeHtml(outage.reason || 'No failure details');
          return `
            <article class="active-outage-item" data-outage-monitor-id="${escapeHtml(outage.monitorId)}">
              <div class="active-outage-head">
                <strong>${safeName}</strong>
                <span class="status down">down</span>
              </div>
              <p class="cell-sub">${safeGroup} - ${safeTarget}</p>
              <p class="cell-sub">Down since: <time class="js-local-time" datetime="${escapeHtml(downSince)}" data-style="datetime">${escapeHtml(downSince || '-')}</time></p>
              <p class="cell-sub">Duration: <span class="js-duration" data-duration-seconds="${duration === null ? '' : duration}">${duration === null ? '-' : `${duration}s`}</span></p>
              <p class="target">${safeReason}</p>
            </article>
          `;
        })
        .join('');
    }

    function updateMonitorRow(row, monitor) {
      const status = monitor.runtime && monitor.runtime.status ? monitor.runtime.status : 'unknown';
      row.classList.remove('up', 'down', 'unknown');
      row.classList.add(status);

      const statusNode = row.querySelector('[data-field="status"]');
      if (statusNode) {
        statusNode.classList.remove('up', 'down', 'unknown');
        statusNode.classList.add(status);
        statusNode.textContent = monitor.hasUnconfirmedFailures ? 'up (confirming)' : status;
      }

      const nameNode = row.querySelector('[data-field="name"]');
      if (nameNode) {
        nameNode.textContent = monitor.name;
      }

      const targetNode = row.querySelector('[data-field="target"]');
      if (targetNode) {
        targetNode.textContent = monitor.target || '-';
        targetNode.setAttribute('title', monitor.target || '-');
      }

      const typeNode = row.querySelector('[data-field="check-type"]');
      if (typeNode) {
        typeNode.textContent = monitor.checkType;
      }

      const activeChip = row.querySelector('[data-field="active-chip"]');
      if (activeChip) {
        activeChip.classList.remove('active', 'paused');
        activeChip.classList.add(monitor.active ? 'active' : 'paused');
        activeChip.textContent = monitor.active ? 'Active' : 'Paused';
      }

      const toggleLabel = row.querySelector('[data-field="toggle-label"]');
      if (toggleLabel) {
        toggleLabel.textContent = monitor.active ? 'Pause' : 'Resume';
      }

      const lastCheckNode = row.querySelector('[data-field="last-check"]');
      setLocalizedTime(lastCheckNode, monitor.runtime ? monitor.runtime.lastCheckAt : null, 'datetime');

      const nextCheckNode = row.querySelector('[data-field="next-check"]');
      setLocalizedTime(nextCheckNode, monitor.runtime ? monitor.runtime.nextCheckAt : null, 'time');

      const outageLabel = row.querySelector('[data-field="outage-label"]');
      const outageDuration = row.querySelector('[data-field="outage-duration"]');
      if (status === 'down' && monitor.outage && monitor.outage.startedAt) {
        if (outageLabel) {
          outageLabel.innerHTML = `<time class="js-local-time" datetime="${escapeHtml(monitor.outage.startedAt)}" data-style="datetime">${escapeHtml(monitor.outage.startedAt)}</time>`;
        }
        if (outageDuration) {
          outageDuration.setAttribute('data-duration-seconds', String(monitor.outage.durationSeconds || 0));
        }
      } else {
        if (outageLabel) {
          outageLabel.textContent = '-';
        }
        if (outageDuration) {
          outageDuration.setAttribute('data-duration-seconds', '');
        }
      }

      const errorNode = row.querySelector('[data-field="last-error"]');
      if (errorNode) {
        const message = monitor.runtime && monitor.runtime.lastError ? monitor.runtime.lastError : '-';
        errorNode.textContent = message;
        errorNode.setAttribute('title', message);
      }
    }

    let pending = false;
    let timer = null;
    let downCount = <%- JSON.stringify(summary ? summary.down : 0) %>;

    function nextDelayMs() {
      return downCount > 0 ? 5000 : 15000;
    }

    function schedule(delayMs) {
      clearTimeout(timer);
      timer = setTimeout(refreshLiveDashboard, delayMs);
    }

    async function refreshLiveDashboard() {
      if (document.visibilityState !== 'visible') {
        schedule(nextDelayMs());
        return;
      }

      if (pending) {
        schedule(5000);
        return;
      }

      pending = true;
      try {
        const response = await fetch('/api/dashboard/live', {
          method: 'GET',
          headers: {
            Accept: 'application/json'
          },
          cache: 'no-store'
        });

        if (!response.ok) {
          return;
        }

        const snapshot = await response.json();
        const payloadIds = monitorIdsFromPayload(snapshot.groupedMonitors || []);
        const domIds = monitorIdsFromDom();
        if (payloadIds.length !== domIds.length || payloadIds.some((id, idx) => id !== domIds[idx])) {
          window.location.reload();
          return;
        }

        for (const [key, value] of Object.entries(snapshot.summary || {})) {
          const node = document.querySelector(`[data-summary="${key}"]`);
          if (node) {
            node.textContent = String(value);
          }
        }
        downCount = snapshot.summary && Number.isFinite(snapshot.summary.down) ? snapshot.summary.down : 0;

        const groupCounts = new Map((snapshot.groupedMonitors || []).map((group) => [group.groupId || 'ungrouped', group.monitors.length]));
        for (const [groupId, count] of groupCounts.entries()) {
          const countNode = document.querySelector(`[data-group-count="${groupId}"]`);
          if (countNode) {
            countNode.textContent = `(${count})`;
          }
        }

        for (const group of snapshot.groupedMonitors || []) {
          for (const monitor of group.monitors) {
            const row = document.querySelector(`tr[data-monitor-id="${monitor.id}"]`);
            if (!row) {
              window.location.reload();
              return;
            }
            updateMonitorRow(row, monitor);
          }
        }

        updateActiveOutages(snapshot);

        const updatedNode = document.getElementById('js-live-updated');
        setLocalizedTime(updatedNode, snapshot.generatedAt, 'datetime');
        renderDurationNodes();
        localizeTimes();
      } catch (_error) {
        // Keep the previous state if live refresh fails.
      } finally {
        pending = false;
        schedule(nextDelayMs() + Math.floor(Math.random() * 1500));
      }
    }

    localizeTimes();
    renderDurationNodes();

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        refreshLiveDashboard();
      }
    });

    schedule(2500 + Math.floor(Math.random() * 1200));
  })();
</script>

<%- include('partials/layout-bottom') %>
