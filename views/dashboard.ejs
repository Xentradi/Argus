<%- include('partials/layout-top', { title: 'Dashboard' }) %>

<section class="grid-stats">
  <article class="stat-card">
    <h2>Total</h2>
    <p><%= summary.total %></p>
  </article>
  <article class="stat-card">
    <h2>Groups</h2>
    <p><%= summary.groups %></p>
  </article>
  <article class="stat-card up">
    <h2>Up</h2>
    <p><%= summary.up %></p>
  </article>
  <article class="stat-card down">
    <h2>Down</h2>
    <p><%= summary.down %></p>
  </article>
  <article class="stat-card unknown">
    <h2>Unknown</h2>
    <p><%= summary.unknown %></p>
  </article>
</section>

<section class="card">
  <div class="section-head">
    <h1>Monitors</h1>
    <div class="row-actions">
      <a class="button muted" href="/groups">Manage Groups</a>
      <a class="button" href="/monitors/new">Add Monitor</a>
    </div>
  </div>

  <% if (groupedMonitors.length === 0) { %>
  <p class="empty">No monitors yet.</p>
  <% } else { %>
    <% groupedMonitors.forEach((group) => { %>
    <h3 class="group-title"><%= group.groupName %> <span>(<%= group.monitors.length %>)</span></h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Target</th>
            <th>Status</th>
            <th>Last Check</th>
            <th>Next Check</th>
            <th>Last Error</th>
            <th>Order</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% group.monitors.forEach((monitor) => { %>
          <% const hasUnconfirmedFailures = monitor.runtime.status === 'up' && Boolean(monitor.runtime.lastError); %>
          <tr>
            <td>
              <div class="cell-title"><%= monitor.name %></div>
              <div class="cell-sub"><%= monitor.active ? 'Active' : 'Paused' %></div>
            </td>
            <td><%= monitor.checkType %></td>
            <td class="target"><%= monitorTarget(monitor) || '-' %></td>
            <td>
              <span class="status <%= monitor.runtime.status %>"><%= hasUnconfirmedFailures ? 'up (confirming)' : monitor.runtime.status %></span>
            </td>
            <td>
              <% if (monitor.runtime.lastCheckAt) { %>
              <time class="js-local-time" datetime="<%= monitor.runtime.lastCheckAt %>" data-style="datetime"><%= monitor.runtime.lastCheckAt %></time>
              <% } else { %>
              Never
              <% } %>
            </td>
            <td>
              <% if (monitor.runtime.nextCheckAt) { %>
              <time class="js-local-time" datetime="<%= monitor.runtime.nextCheckAt %>" data-style="time"><%= monitor.runtime.nextCheckAt %></time>
              <% } else { %>
              -
              <% } %>
            </td>
            <td class="target"><%= monitor.runtime.lastError || '-' %></td>
            <td>
              <div class="row-actions">
                <form action="/monitors/<%= monitor.id %>/move" method="post">
                  <input type="hidden" name="direction" value="up" />
                  <button class="button small muted" type="submit" aria-label="Move up">↑</button>
                </form>
                <form action="/monitors/<%= monitor.id %>/move" method="post">
                  <input type="hidden" name="direction" value="down" />
                  <button class="button small muted" type="submit" aria-label="Move down">↓</button>
                </form>
              </div>
            </td>
            <td>
              <div class="row-actions">
                <a class="button small muted" href="/monitors/<%= monitor.id %>/edit">Edit</a>
                <form action="/monitors/<%= monitor.id %>/toggle" method="post">
                  <button class="button small" type="submit"><%= monitor.active ? 'Pause' : 'Resume' %></button>
                </form>
                <form action="/monitors/<%= monitor.id %>/delete" method="post" onsubmit="return confirm('Delete this monitor?');">
                  <button class="button small danger" type="submit">Delete</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% }) %>
  <% } %>
</section>

<section class="card">
  <h2>Incident History (3 years retained)</h2>

  <% if (incidents.length === 0) { %>
  <p class="empty">No incidents recorded yet.</p>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Monitor</th>
          <th>Started</th>
          <th>Ended</th>
          <th>Duration</th>
          <th>Down Reason</th>
          <th>Recovery</th>
        </tr>
      </thead>
      <tbody>
        <% incidents.forEach((incident) => { %>
        <tr>
          <td><%= incident.monitorName %></td>
          <td><time class="js-local-time" datetime="<%= incident.startedAt %>" data-style="datetime"><%= incident.startedAt %></time></td>
          <td>
            <% if (incident.endedAt) { %>
            <time class="js-local-time" datetime="<%= incident.endedAt %>" data-style="datetime"><%= incident.endedAt %></time>
            <% } else { %>
            Open
            <% } %>
          </td>
          <td><%= incident.durationSeconds === null ? '-' : `${incident.durationSeconds}s` %></td>
          <td class="target"><%= incident.downReason || '-' %></td>
          <td class="target"><%= incident.recoveryReason || '-' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h2>Event Log</h2>
    <p class="subtitle">Page <%= eventPagination.page %> of <%= eventPagination.totalPages %></p>
  </div>

  <% if (events.length === 0) { %>
  <p class="empty">No events yet.</p>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Time</th>
          <th>Monitor</th>
          <th>Type</th>
          <th>Message</th>
        </tr>
      </thead>
      <tbody>
        <% events.forEach((event) => { %>
        <tr>
          <td><time class="js-local-time" datetime="<%= event.createdAt %>" data-style="datetime"><%= event.createdAt %></time></td>
          <td><%= event.monitorName || '-' %></td>
          <td><%= event.eventType %></td>
          <td class="target"><%= event.message %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

  <% if (eventPagination.totalPages > 1) { %>
  <div class="row-actions">
    <% if (eventPagination.hasPrev) { %>
    <a class="button small muted" href="/?eventsPage=<%= eventPagination.page - 1 %>">Previous</a>
    <% } %>
    <% if (eventPagination.hasNext) { %>
    <a class="button small muted" href="/?eventsPage=<%= eventPagination.page + 1 %>">Next</a>
    <% } %>
  </div>
  <% } %>
</section>

<script>
  (function () {
    function localizeTimes() {
      const nodes = document.querySelectorAll('.js-local-time[datetime]');
      for (const node of nodes) {
        const iso = node.getAttribute('datetime');
        if (!iso) {
          continue;
        }

        const date = new Date(iso);
        if (Number.isNaN(date.getTime())) {
          continue;
        }

        const style = node.getAttribute('data-style') || 'datetime';
        if (style === 'time') {
          node.textContent = date.toLocaleTimeString();
        } else {
          node.textContent = date.toLocaleString();
        }
      }
    }

    localizeTimes();

    const refreshMs = 15000;
    let timer = null;

    function scheduleRefresh() {
      clearTimeout(timer);
      timer = setTimeout(() => {
        if (document.visibilityState === 'visible') {
          window.location.reload();
          return;
        }
        scheduleRefresh();
      }, refreshMs);
    }

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        scheduleRefresh();
      }
    });

    scheduleRefresh();
  })();
</script>

<%- include('partials/layout-bottom') %>
