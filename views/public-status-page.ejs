<%
  function formatStateDuration(seconds, status) {
    if (!Number.isFinite(seconds) || seconds < 0) {
      return '-';
    }

    const totalSeconds = Math.floor(seconds);
    const days = Math.floor(totalSeconds / 86400);
    const hours = Math.floor((totalSeconds % 86400) / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    const secs = totalSeconds % 60;
    const parts = [];

    if (days > 0) {
      parts.push(`${days}d`);
    }
    if (hours > 0 || days > 0) {
      parts.push(`${hours}h`);
    }
    if (minutes > 0 || hours > 0 || days > 0) {
      parts.push(`${minutes}m`);
    }
    parts.push(`${secs}s`);

    const prefix = status === 'down' ? 'Down for ' : status === 'up' ? 'Up for ' : '';
    return `${prefix}${parts.join(' ')}`;
  }
%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= statusPage ? `${statusPage.name} - ${appName}` : `Status Page - ${appName}` %></title>
    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/img/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="public-status-body">
    <div class="page-background"></div>
    <main class="public-status-shell">
      <section class="card public-status-card">

  <% if (!statusPage) { %>
  <h1>Status Page Not Found</h1>
  <p>This status page link is invalid or no longer available.</p>
  <% } else { %>
  <h1><%= statusPage.name %></h1>
  <div class="public-status-counters">
    <article class="public-status-counter up">
      <span class="label">Up</span>
      <strong id="js-public-up-count"><%= summary.up %></strong>
    </article>
    <article class="public-status-counter down">
      <span class="label">Down</span>
      <strong id="js-public-down-count"><%= summary.down %></strong>
    </article>
    <article class="public-status-counter unknown">
      <span class="label">Unknown</span>
      <strong id="js-public-unknown-count"><%= summary.unknown %></strong>
    </article>
  </div>

  <div class="row-actions status-live-meta">
    <span class="live-pill">Live</span>
    <span class="cell-sub" id="js-public-summary"><%= summary.up %> up, <%= summary.down %> down, <%= summary.unknown %> unknown</span>
    <span class="cell-sub">Updated <time id="js-public-updated" class="js-local-time" datetime="<%= generatedAt %>" data-style="datetime"><%= generatedAt %></time></span>
  </div>

  <% if (monitors.length === 0) { %>
  <p class="empty">No monitors are assigned to this status page.</p>
  <% } else { %>
  <div class="table-wrap">
    <table class="public-status-table">
      <thead>
        <tr>
          <th>Status</th>
          <th>Name</th>
          <th>Uptime</th>
          <th>Current Duration</th>
        </tr>
      </thead>
      <tbody>
        <% monitors.forEach((monitor) => { %>
        <tr
          data-monitor-id="<%= monitor.id %>"
          data-uptime-ratio="<%= monitor.uptimeRatio === null || monitor.uptimeRatio === undefined ? '' : monitor.uptimeRatio %>"
          class="public-status-row state-<%= monitor.status %>"
        >
          <td><span class="status <%= monitor.status %>" data-field="status"><%= monitor.status %></span></td>
          <td data-field="name"><%= monitor.name %></td>
          <td class="uptime-cell" data-field="uptime"><%= monitor.uptimePercent %></td>
          <td class="state-duration-cell">
            <span
              data-field="state-duration"
              data-state="<%= monitor.status %>"
              data-duration-seconds="<%= monitor.stateDurationSeconds === null || monitor.stateDurationSeconds === undefined ? '' : monitor.stateDurationSeconds %>"
            ><%= formatStateDuration(monitor.stateDurationSeconds, monitor.status) %></span>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
  <% } %>
      </section>
    </main>

<script>
  (function () {
    function setLocalizedTime(node, iso, style) {
      if (!node || !iso) {
        return;
      }

      const date = new Date(iso);
      if (Number.isNaN(date.getTime())) {
        node.textContent = iso;
        return;
      }

      node.setAttribute('datetime', iso);
      node.setAttribute('data-style', style || 'datetime');
      node.textContent = style === 'time' ? date.toLocaleTimeString() : date.toLocaleString();
    }

    function localizeTimes(root) {
      const scope = root || document;
      const nodes = scope.querySelectorAll('.js-local-time[datetime]');
      for (const node of nodes) {
        setLocalizedTime(node, node.getAttribute('datetime'), node.getAttribute('data-style') || 'datetime');
      }
    }

    localizeTimes(document);

    const pageSlug = <%- JSON.stringify(statusPage ? statusPage.slug : null) %>;
    if (!pageSlug) {
      return;
    }

    function monitorIdsFromPayload(monitors) {
      return monitors.map((monitor) => monitor.id).sort();
    }

    function applyUptimeGradient(row, uptimeRatio) {
      if (!row) {
        return;
      }

      if (!Number.isFinite(uptimeRatio)) {
        row.classList.remove('uptime-gradient');
        row.style.removeProperty('--uptime-fill');
        return;
      }

      const clamped = Math.max(0, Math.min(1, uptimeRatio));
      row.classList.add('uptime-gradient');
      row.style.setProperty('--uptime-fill', `${(clamped * 100).toFixed(3)}%`);
      row.setAttribute('data-uptime-ratio', String(clamped));
    }

    function formatStateDuration(seconds, status) {
      if (!Number.isFinite(seconds) || seconds < 0) {
        return '-';
      }

      const totalSeconds = Math.floor(seconds);
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((totalSeconds % 86400) / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const secs = totalSeconds % 60;
      const parts = [];

      if (days > 0) {
        parts.push(`${days}d`);
      }
      if (hours > 0 || days > 0) {
        parts.push(`${hours}h`);
      }
      if (minutes > 0 || hours > 0 || days > 0) {
        parts.push(`${minutes}m`);
      }
      parts.push(`${secs}s`);

      const prefix = status === 'down' ? 'Down for ' : status === 'up' ? 'Up for ' : '';
      return `${prefix}${parts.join(' ')}`;
    }

    function tickStateDurations() {
      if (document.visibilityState !== 'visible') {
        return;
      }

      const nodes = document.querySelectorAll('[data-field="state-duration"]');
      for (const node of nodes) {
        const status = node.getAttribute('data-state') || 'unknown';
        if (status !== 'up' && status !== 'down') {
          continue;
        }

        const seconds = Number(node.getAttribute('data-duration-seconds'));
        if (!Number.isFinite(seconds) || seconds < 0) {
          continue;
        }

        const nextSeconds = seconds + 1;
        node.setAttribute('data-duration-seconds', String(nextSeconds));
        node.textContent = formatStateDuration(nextSeconds, status);
      }
    }

    function monitorIdsFromDom() {
      return Array.from(document.querySelectorAll('tr[data-monitor-id]'))
        .map((node) => node.getAttribute('data-monitor-id'))
        .sort();
    }

    let pending = false;
    let timer = null;
    let downCount = <%- JSON.stringify(summary ? summary.down : 0) %>;

    for (const row of document.querySelectorAll('tr[data-monitor-id]')) {
      const ratio = Number(row.getAttribute('data-uptime-ratio'));
      applyUptimeGradient(row, ratio);
    }

    function nextDelayMs() {
      return downCount > 0 ? 10000 : 30000;
    }

    function schedule(delayMs) {
      clearTimeout(timer);
      timer = setTimeout(runLiveRefresh, delayMs);
    }

    async function runLiveRefresh() {
      if (document.visibilityState !== 'visible') {
        schedule(nextDelayMs());
        return;
      }

      if (pending) {
        schedule(5000);
        return;
      }

      pending = true;
      try {
        const response = await fetch(`/api/status/${encodeURIComponent(pageSlug)}/live`, {
          method: 'GET',
          headers: {
            Accept: 'application/json'
          },
          cache: 'no-store'
        });

        if (!response.ok) {
          if (response.status === 404) {
            window.location.reload();
            return;
          }
          schedule(nextDelayMs());
          return;
        }

        const snapshot = await response.json();
        const payloadIds = monitorIdsFromPayload(snapshot.monitors || []);
        const domIds = monitorIdsFromDom();
        if (payloadIds.length !== domIds.length || payloadIds.some((id, idx) => id !== domIds[idx])) {
          window.location.reload();
          return;
        }

        for (const monitor of snapshot.monitors || []) {
          const row = document.querySelector(`tr[data-monitor-id="${monitor.id}"]`);
          if (!row) {
            window.location.reload();
            return;
          }

          const statusNode = row.querySelector('[data-field="status"]');
          if (statusNode) {
            statusNode.classList.remove('up', 'down', 'unknown');
            statusNode.classList.add(monitor.status || 'unknown');
            statusNode.textContent = monitor.status || 'unknown';
          }
          row.classList.remove('state-up', 'state-down', 'state-unknown');
          row.classList.add(`state-${monitor.status || 'unknown'}`);
          applyUptimeGradient(row, monitor.uptimeRatio);

          const nameNode = row.querySelector('[data-field="name"]');
          if (nameNode) {
            nameNode.textContent = monitor.name;
          }

          const uptimeNode = row.querySelector('[data-field="uptime"]');
          if (uptimeNode) {
            uptimeNode.textContent = monitor.uptimePercent;
          }

          const durationNode = row.querySelector('[data-field="state-duration"]');
          if (durationNode) {
            durationNode.setAttribute('data-state', monitor.status || 'unknown');
            if (monitor.stateDurationSeconds === null || monitor.stateDurationSeconds === undefined) {
              durationNode.setAttribute('data-duration-seconds', '');
              durationNode.textContent = '-';
            } else {
              durationNode.setAttribute('data-duration-seconds', String(monitor.stateDurationSeconds));
              durationNode.textContent = formatStateDuration(monitor.stateDurationSeconds, monitor.status || 'unknown');
            }
          }
        }

        const summaryNode = document.getElementById('js-public-summary');
        if (summaryNode && snapshot.summary) {
          summaryNode.textContent = `${snapshot.summary.up} up, ${snapshot.summary.down} down, ${snapshot.summary.unknown} unknown`;
        }
        const upCountNode = document.getElementById('js-public-up-count');
        if (upCountNode && snapshot.summary) {
          upCountNode.textContent = snapshot.summary.up;
        }
        const downCountNode = document.getElementById('js-public-down-count');
        if (downCountNode && snapshot.summary) {
          downCountNode.textContent = snapshot.summary.down;
        }
        const unknownCountNode = document.getElementById('js-public-unknown-count');
        if (unknownCountNode && snapshot.summary) {
          unknownCountNode.textContent = snapshot.summary.unknown;
        }

        downCount = snapshot.summary && Number.isFinite(snapshot.summary.down) ? snapshot.summary.down : 0;

        const updatedNode = document.getElementById('js-public-updated');
        setLocalizedTime(updatedNode, snapshot.generatedAt, 'datetime');
      } catch (_error) {
        // Keep current state when refresh fails.
      } finally {
        pending = false;
        schedule(nextDelayMs() + Math.floor(Math.random() * 1200));
      }
    }

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        runLiveRefresh();
      }
    });

    schedule(4000 + Math.floor(Math.random() * 1200));
    setInterval(tickStateDurations, 1000);
  })();
</script>
  </body>
</html>
